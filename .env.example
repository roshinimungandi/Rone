# Copy this file to .env and fill in your keys.

# NewsAPI — https://newsapi.org (100 requests/day on developer plan)
NEWS_API_KEY=your_newsapi_key_here

# YouTube Data API v3 — https://console.cloud.google.com (10,000 units/day free)
# Enable "YouTube Data API v3" in your project, then create an API key.
YOUTUBE_API_KEY=your_youtube_api_key_here

NODE_TLS_REJECT_UNAUTHORIZED=0
